# Usage: gen-asm-deps <asm-jar> <java-build-dir> <target> <make-bin>
#
# Writes a Make include file to stdout with two rules:
#   1. Extract ASM class files from the jar (grouped target if Make >= 4.3,
#      stamp file otherwise).
#   2. Make <target> depend on those class files (or the stamp).
set -e

ASM_JAR="$1"
JAVA_BUILD_DIR="$2"
TARGET="$3"
MAKE_BIN="${4:-make}"

# Detect Make version for grouped-target (&:) support (requires >= 4.3)
MAKE_VERSION=$("${MAKE_BIN}" --version 2>/dev/null \
	| head -1 | grep -oE '[0-9]+\.[0-9]+' | head -1)
MAKE_MAJOR=$(echo "${MAKE_VERSION}" | cut -d. -f1)
MAKE_MINOR=$(echo "${MAKE_VERSION}" | cut -d. -f2)

USE_GROUPED=0
if [ -n "${MAKE_MAJOR}" ] && [ -n "${MAKE_MINOR}" ]; then
	if [ "${MAKE_MAJOR}" -gt 4 ] || \
	   ([ "${MAKE_MAJOR}" -eq 4 ] && [ "${MAKE_MINOR}" -ge 3 ]); then
		USE_GROUPED=1
	fi
fi

# Locate the jar tool
if [ -n "${JAVA_HOME}" ]; then
	JAR_BIN="${JAVA_HOME}/bin/jar"
else
	JAR_BIN=jar
fi

# Build the list of class files that will be extracted.
# Filter out root-level module-info.class — it's not in org/ and won't be extracted.
# Escape $ to $$ so Make doesn't interpret inner-class names as variable references.
mapfile -t CLASS_FILES < <(
	"${JAR_BIN}" tf "${ASM_JAR}" \
		| grep '\.class$' \
		| grep -v '^module-info\.class$' \
		| sed "s|^|${JAVA_BUILD_DIR}/|; s/\\\$/\$\$/g"
)

if [ "${#CLASS_FILES[@]}" -eq 0 ]; then
	echo "gen-asm-deps: no class files found in ${ASM_JAR}" >&2
	exit 1
fi

LAST=$(( ${#CLASS_FILES[@]} - 1 ))

echo "# Auto-generated by gen-asm-deps -- do not edit"
echo ""

if [ "${USE_GROUPED}" = "1" ]; then
	# Grouped-target form: one recipe run extracts all files (Make >= 4.3)
	for i in "${!CLASS_FILES[@]}"; do
		if [ "${i}" -lt "${LAST}" ]; then
			printf '%s \\\n' "${CLASS_FILES[$i]}"
		else
			printf '%s &: %s\n' "${CLASS_FILES[$i]}" "${ASM_JAR}"
		fi
	done
	printf '\tJAVA_HOME=$(JAVA_HOME) build-src/extract-asm $(ASM_JAR) $(JAVA_BUILD_DIR)\n'
	echo ""
	# Make the jar target depend on the extracted class files
	printf '%s: \\\n' "${TARGET}"
	for i in "${!CLASS_FILES[@]}"; do
		if [ "${i}" -lt "${LAST}" ]; then
			printf '%s \\\n' "${CLASS_FILES[$i]}"
		else
			printf '%s\n' "${CLASS_FILES[$i]}"
		fi
	done
else
	# Stamp-file form: single stamp tracks the extraction (Make < 4.3)
	STAMP="$(dirname "${ASM_JAR}")/asm-extracted.stamp"
	printf '%s: %s\n' "${STAMP}" "${ASM_JAR}"
	printf '\tJAVA_HOME=$(JAVA_HOME) build-src/extract-asm $(ASM_JAR) $(JAVA_BUILD_DIR)\n'
	printf '\t@touch $@\n'
	echo ""
	printf '%s: %s\n' "${TARGET}" "${STAMP}"
fi
